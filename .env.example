# Production URL — used in canonical, sitemap, OG, JSON-LD, robots host.
NEXT_PUBLIC_SITE_URL=https://crewsheet.app

# Brand / founder
NEXT_PUBLIC_FOUNDER_NAME=Your Name
NEXT_PUBLIC_FOUNDER_TITLE=Founder
NEXT_PUBLIC_CONTACT_EMAIL=hello@crewsheet.app
NEXT_PUBLIC_AFFILIATES_EMAIL=affiliates@crewsheet.app
NEXT_PUBLIC_TWITTER_HANDLE=@crewsheet
NEXT_PUBLIC_GITHUB_URL=

# Checkout URLs (Stripe Payment Link / Gumroad / Stan Store / Lemon Squeezy)
NEXT_PUBLIC_CHECKOUT_DIY=
NEXT_PUBLIC_CHECKOUT_DFY=
NEXT_PUBLIC_CHECKOUT_PRO=

# Booking link for the "Book a 15-min demo" CTA (Cal.com / Savvycal / Calendly)
NEXT_PUBLIC_DEMO_BOOKING_URL=

# Lead-capture webhook for the savings calculator email form.
# Receives a JSON POST with { email, jobs, avg, yearJobber, yearCrew, save, lang, source, ts }.
NEXT_PUBLIC_LEAD_WEBHOOK_URL=

# Analytics (either or both, both optional)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Set to "1" once you have 3 real testimonials in src/lib/i18n.ts
NEXT_PUBLIC_SHOW_TESTIMONIALS=

# ISO date last reviewed by counsel; shown on legal pages
NEXT_PUBLIC_LEGAL_UPDATED=2026-04-27
